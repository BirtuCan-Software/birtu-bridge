# Server
NODE_ENV=development
PORT=3000

# MySQL (cPanel shared hosting values go here)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_cpanel_db_user
DB_PASSWORD=your_cpanel_db_password
DB_NAME=your_cpanel_db_name
DB_POOL_MAX=8
DB_CONNECT_TIMEOUT_MS=10000

# Chapa (used starting Phase 3)
CHAPA_SECRET_KEY=CHASECK_TEST-xxxxxxxxxxxxxxxxxxxx
CHAPA_WEBHOOK_SECRET=your_chapa_webhook_secret
CHAPA_API_BASE=https://api.chapa.co/v1
CHAPA_TIMEOUT_MS=7000

# Circuit breaker
CIRCUIT_BREAKER_COOLDOWN_SECONDS=30
CIRCUIT_BREAKER_PROBE_STALE_SECONDS=15

# Reconciler / cron
RECONCILER_FORWARDING_STALE_MINUTES=5
RECONCILER_RECOVERING_STALE_SECONDS=15
RECONCILER_INITIALIZED_STALE_MINUTES=10
JOB_LOCK_TTL_MINUTES=5

# Admin
ADMIN_TOKEN=change_me_to_a_long_random_string_before_deploying

# Rate limiting
RATE_LIMIT_PER_MINUTE_PER_KEY=60
RATE_LIMIT_PER_MINUTE_PER_IP=20

# Public base URL (used as the Chapa callback_url target)
PUBLIC_BASE_URL=http://localhost:3000

# Webhook signature verification
CHAPA_WEBHOOK_SIGNATURE_HEADER=Chapa-Signature

# Outbound delivery worker
DELIVERY_MAX_ATTEMPTS=8
DELIVERY_BACKOFF_BASE_SECONDS=5
DELIVERY_TIMEOUT_MS=8000

# DLQ alerting
ALERT_EMAIL_TO=you@example.com
ALERT_EMAIL_FROM=no-reply@birtu-bridge.local

# Admin UI session
SESSION_SECRET=change_me_to_a_long_random_string_before_deploying
SESSION_COOKIE_NAME=birtu_admin_sid
SESSION_TTL_HOURS=12
LOGIN_RATE_LIMIT_PER_MINUTE=5
