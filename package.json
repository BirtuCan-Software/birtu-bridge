{
  "name": "birtu-bridge",
  "version": "1.0.0",
  "description": "Payment proxy gateway for Chapa - Fastify + MySQL",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node scripts/migrate.js",
    "reconcile": "node scripts/run-reconciler.js",
    "deliver": "node scripts/run-delivery-worker.js",
    "digest": "node scripts/run-dlq-digest.js",
    "create-admin": "node scripts/create-admin-user.js",
    "build:css": "tailwindcss -i ./src/styles/input.css -o ./src/public/app.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/input.css -o ./src/public/app.css --watch"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/csrf-protection": "^6.4.1",
    "@fastify/formbody": "^7.4.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/session": "^10.9.0",
    "@fastify/static": "^7.0.4",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "mysql2": "^3.11.0",
    "nodemailer": "^9.0.3",
    "pino-pretty": "^11.2.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "tailwindcss": "^3.4.19"
  }
}
